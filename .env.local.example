# Salin file ini menjadi .env.local lalu isi dengan nilai aslimu.
# cp .env.local.example .env.local

# ─── EmailJS ───────────────────────────────────────────────
# Dapatkan dari https://www.emailjs.com
# Account > Email Services  → Service ID
# Account > Email Templates → Template ID
# Account > General         → Public Key

NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_emailjs_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# ─── Supabase ──────────────────────────────────────────────
# Dapatkan dari https://supabase.com → Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
SUPABASE_SECRET_KEY=sb_secret_your_key

# ─── Supabase Postgres ─────────────────────────────────────
# Dapatkan dari https://supabase.com → Project Settings > Database
POSTGRES_URL=postgres://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x
POSTGRES_URL_NON_POOLING=postgres://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
POSTGRES_PRISMA_URL=postgres://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DATABASE=postgres
POSTGRES_HOST=db.your-project-id.supabase.co

# ─── GitHub ────────────────────────────────────────────────
# Personal Access Token (classic or fine-grained) — server-side only, NEVER public.
# Required scopes: read:user  (for contributionsCollection via GraphQL)
# Create at: https://github.com/settings/tokens/new?scopes=read:user
GITHUB_TOKEN=github_pat_your_token_here

# ─── Entertainment Page ────────────────────────────────────

# Steam API Key (server-side only) — https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key

# Steam ID profil kamu — https://steamid.io
NEXT_PUBLIC_STEAM_ID=your_steam_id

# TMDB (The Movie Database) — https://www.themoviedb.org/settings/api (gratis)
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key

# Google Books API — https://console.cloud.google.com (opsional, aman tanpa key)
NEXT_PUBLIC_GOOGLE_BOOKS_API_KEY=your_google_books_api_key

# Spotify — tidak butuh API key, cukup User ID profil Spotify kamu
NEXT_PUBLIC_SPOTIFY_USER_ID=your_spotify_user_id
